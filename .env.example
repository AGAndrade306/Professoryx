# === Banco de Dados (Neon PostgreSQL) ===
# No Neon dashboard: Connection Details > selecione "Prisma" > copie a connection string
DATABASE_URL="postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/professoryx?sslmode=require"

# === OpenAI ===
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# === SerpAPI (busca web) ===
# Crie em: https://serpapi.com/manage-api-key (100 buscas/mês grátis)
SERPAPI_KEY="..."

# === Gamma API ===
GAMMA_API_KEY="..."

# === Auth ===
# Gere com: openssl rand -base64 32
JWT_SECRET="change-me-in-production"

# === App ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"
