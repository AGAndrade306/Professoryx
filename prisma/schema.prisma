generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
  materias  Materia[]
  aulas     Aula[]
}

model Materia {
  id                     String   @id @default(uuid())
  userId                 String
  nome                   String
  ementa                 String   @db.Text
  conteudoProgramatico   String   @db.Text
  estiloVisualPadrao     String   @default("tech-academico")
  estiloVisualCustom     String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  usuario                Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  aulas                  Aula[]
}

model Aula {
  id                  String   @id @default(uuid())
  userId              String
  materiaId           String
  tema                String
  quantidadeSlides    Int      @default(10)
  linksExtras         String?  @db.Text
  materialExtraTexto  String?  @db.Text
  observacoesIA       String?  @db.Text
  perfilPublico       String   @default("graduacao")
  nivelAula           String   @default("intermediaria")
  status              String   @default("rascunho")
  resultadoPesquisa   String?  @db.Text
  promptFinalEnviado  String?  @db.Text
  respostaOpenAI      String?  @db.Text
  tituloAula          String?
  gammaGenerationId   String?
  gammaPreviewUrl     String?
  gammaDownloadUrl    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  usuario             Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  materia             Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  slides              Slide[]
}

model Slide {
  id            String   @id @default(uuid())
  aulaId        String
  numero        Int
  titulo        String
  conteudo      String   @db.Text
  observacoes   String?  @db.Text
  editadoManual Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  aula          Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
}
